<!-- Proffesional ui -->

<%- include('./partials/header') %>

<div class="w-full min-h-screen flex bg-zinc-50 font-['helvetica']">
    
    <div class="w-[22%] h-screen sticky top-0 px-10 py-16 border-r border-zinc-200 bg-white">
        
        <div class="mb-12">
            <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-4">Display Options</h3>
            <form action="/shop" class="flex flex-col gap-2">
                <label class="text-sm font-medium text-zinc-600">Sort by</label>
                <select onchange="this.form.submit()" class="w-full border border-zinc-200 px-4 py-3 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-100 transition-all cursor-pointer" name="sortby">
                    <option value="popular">Most Popular</option>
                    <option value="newest">Newest Arrivals</option>
                </select>
            </form>
        </div>

        <div class="flex flex-col gap-5 mb-16">
            <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-1">Categories</h3>
            <a class="text-sm font-semibold text-zinc-500 hover:text-blue-600 transition-all flex items-center gap-2 group" href="">
                <span class="w-0 h-[2px] bg-blue-600 group-hover:w-4 transition-all"></span> New Collection
            </a>
            <a class="text-sm font-semibold text-zinc-900 flex items-center gap-2" href="">
                <span class="w-4 h-[2px] bg-blue-600"></span> All Products
            </a>
            <a class="text-sm font-semibold text-zinc-500 hover:text-blue-600 transition-all flex items-center gap-2 group" href="">
                <span class="w-0 h-[2px] bg-blue-600 group-hover:w-4 transition-all"></span> Seasonal Sales
            </a>
        </div>

        <div>
            <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-400 mb-4">Quick Filters</h3>
            <div class="flex flex-col gap-3">
                <label class="flex items-center gap-3 text-sm text-zinc-600 cursor-pointer hover:text-black">
                    <input type="checkbox" class="accent-blue-600 w-4 h-4"> Availability
                </label>
                <label class="flex items-center gap-3 text-sm text-zinc-600 cursor-pointer hover:text-black">
                    <input type="checkbox" class="accent-blue-600 w-4 h-4"> On Discount
                </label>
            </div>
        </div>
    </div>

    <div class="w-[78%] p-12">
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            
            <% if(products.length == 0){ %>
                <div class="col-span-full h-96 flex flex-col items-center justify-center border-2 border-dashed border-zinc-200 rounded-3xl">
                    <h1 class="text-xl font-bold text-zinc-400 tracking-tight">Empty Inventory</h1>
                    <p class="text-zinc-300 text-sm italic mt-2">Add some products to see the magic.</p>
                </div>
            <% } %>

            <% products.forEach(function(product){ %>
                <div class="group flex flex-col bg-white rounded-[2rem] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-500 border border-zinc-100">
                    
                    <div style="background-color: <%= product.bgcolor %>" class="w-full h-72 flex items-center justify-center relative overflow-hidden">
                        <img class="h-[14rem] group-hover:scale-110 transition-transform duration-700 ease-out drop-shadow-2xl" 
                             src="data:image/jpeg;base64,<%= product.image.toString('base64') %>" alt="">
                        
                        <% if(product.discount > 0) { %>
                            <span class="absolute top-6 right-6 bg-white/90 backdrop-blur-md px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest text-zinc-800 italic shadow-sm">
                                -₹<%= product.discount %>
                            </span>
                        <% } %>
                    </div>

                    <div style="background-color: <%= product.panelcolor %>; color: <%= product.textcolor %>" class="flex justify-between items-center px-8 py-8">
                        <div>
                            <h3 class="text-xl font-bold tracking-tight mb-1"><%= product.name %></h3>
                            <h4 class="text-lg font-medium opacity-80">₹ <%= product.price %></h4>
                        </div>
                        
                        <a class="w-12 h-12 flex items-center justify-center rounded-2xl bg-white text-black hover:bg-black hover:text-white transition-all shadow-lg active:scale-90" 
                           href="/addtocart/<%=product._id%>">
                            <i class="ri-add-line text-xl"></i>
                        </a>
                    </div>
                </div>
            <% }) %>

        </div>
    </div>
</div>

<%- include('./partials/footer') %>
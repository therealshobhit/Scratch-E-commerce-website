<!-- now professional ui code -->
 <%- include('./partials/header') %>

<% if(error.length > 0){ %>
    <div class="fixed top-10 left-1/2 -translate-x-1/2 z-[999] px-6 py-3 rounded-xl bg-red-500 shadow-2xl shadow-red-200 animate-pulse">
        <span class="text-sm font-bold text-white tracking-tight flex items-center gap-2">
            <i class="ri-error-warning-line"></i> <%= error %>
        </span>
    </div>
<% } else if(message.length > 0){ %>
    <div class="fixed top-10 left-1/2 -translate-x-1/2 z-[999] px-6 py-3 rounded-xl bg-zinc-900 shadow-2xl">
        <span class="text-sm font-bold text-white tracking-tight flex items-center gap-2">
            <i class="ri-checkbox-circle-line text-blue-400"></i> <%= message %>
        </span>
    </div>
<% } %>

<div class="w-full min-h-screen bg-[#fbfbfb] flex font-['helvetica']">
    
    <div class="w-1/2 flex items-center justify-center border-r border-zinc-100 px-20">
        <div class="w-full max-w-md">
            <div class="mb-12">
                <h3 class="text-5xl font-black tracking-tighter text-zinc-900">
                    Join <span class="text-blue-600">Scatch.</span>
                </h3>
                <p class="text-zinc-400 mt-2 font-medium">Create your imperial account</p>
            </div>

            <form autocomplete="off" action="/user/register" method="post" class="space-y-4">
                <div class="group">
                    <label class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest ml-1">Full Identity</label>
                    <input class="w-full px-5 py-4 bg-white border border-zinc-200 rounded-2xl focus:border-blue-500 focus:ring-4 focus:ring-blue-50 transition-all outline-none mt-1"
                           type="text" placeholder="e.g. Ramu Bansal" name="fullname">
                </div>
                
                <div class="group">
                    <label class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest ml-1">Email</label>
                    <input class="w-full px-5 py-4 bg-white border border-zinc-200 rounded-2xl focus:border-blue-500 focus:ring-4 focus:ring-blue-50 transition-all outline-none mt-1"
                           type="email" placeholder="name@ww" name="email">
                </div>

                <div class="group">
                    <label class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest ml-1">Security Key</label>
                    <input class="w-full px-5 py-4 bg-white border border-zinc-200 rounded-2xl focus:border-blue-500 focus:ring-4 focus:ring-blue-50 transition-all outline-none mt-1"
                           type="password" placeholder="••••••••" name="password">
                </div>

                <button type="submit" class="w-full py-5 bg-blue-600 text-white rounded-2xl font-bold text-sm hover:bg-blue-700 shadow-xl shadow-blue-100 transition-all active:scale-[0.98] mt-4">
                    Initialize Account
                </button>
            </form>
        </div>
    </div>

    <div class="w-1/2 flex items-center justify-center bg-white px-20 relative overflow-hidden">
        <div class="absolute -top-20 -right-20 w-64 h-64 bg-blue-50 rounded-full blur-3xl opacity-50"></div>
        <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-blue-50 rounded-full blur-3xl opacity-50"></div>

        <div class="w-full max-w-md relative z-10">
            <div class="mb-12">
                <h4 class="text-3xl font-bold text-zinc-900 tracking-tight">Welcome Back.</h4>
                <p class="text-zinc-400 mt-1">Access your saved collections.</p>
            </div>

            <form autocomplete="off" action="/user/login" method="post" class="space-y-4">
                <div class="group">
                    <input class="w-full px-5 py-4 bg-zinc-50 border border-zinc-100 rounded-2xl focus:bg-white focus:border-blue-500 transition-all outline-none"
                           type="email" placeholder="Registered Email" name="email">
                </div>

                <div class="group">
                    <input class="w-full px-5 py-4 bg-zinc-50 border border-zinc-100 rounded-2xl focus:bg-white focus:border-blue-500 transition-all outline-none"
                           type="password" placeholder="Password" name="password">
                </div>

                <div class="flex items-center justify-between px-1">
                    <label class="flex items-center gap-2 text-xs text-zinc-400 cursor-pointer">
                        <input type="checkbox" class="accent-blue-600"> Remember me
                    </label>
                    <a href="#" class="text-xs font-bold text-blue-600 hover:underline">Forgot Key?</a>
                </div>

                <button type="submit" class="w-full py-5 bg-zinc-900 text-white rounded-2xl font-bold text-sm hover:bg-black transition-all active:scale-[0.98] mt-4 shadow-xl shadow-zinc-100">
                    Log In to Dashboard
                </button>
            </form>
            
        </div>
    </div>
</div>

<%- include('./partials/footer') %>
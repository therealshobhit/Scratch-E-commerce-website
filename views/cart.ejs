<!-- now code for professional ui  -->
 <%- include('./partials/header') %>

<div class="w-full min-h-screen bg-[#f8f8f8] px-10 py-10 font-['helvetica']">
    
    <div class="flex items-center gap-3 mb-10">
        <h1 class="text-3xl font-semibold tracking-tighter text-zinc-800">Your Selection</h1>
        <span class="px-3 py-1 bg-zinc-200 rounded-full text-xs font-bold"><%= user.cart.length %> ITEMS</span>
    </div>

    <% if (user.cart && user.cart.length > 0) { %>
        <div class="flex flex-col lg:flex-row gap-12">
            
            <div class="w-full lg:w-[60%] flex flex-col gap-5">
                <% user.cart.forEach(function(item){ %>
                    <div class="flex w-full bg-white rounded-2xl shadow-[0_1px_3px_rgba(0,0,0,0.1)] border-[1px] border-zinc-100 overflow-hidden">
                        
                        <div class="w-44 h-52 bg-zinc-100 shrink-0">
                            <% if(item.image) { %>
                                <img class="w-full h-full object-cover" 
                                     src="data:image/jpeg;base64, <%= item.image.toString('base64') %>" 
                                     alt="product">
                            <% } %>
                        </div>

                        <div class="flex-1 p-6 flex flex-col justify-between">
                            <div class="flex justify-between">
                                <div>
                                    <h3 class="text-lg font-bold text-zinc-900"><%= item.name %></h3>
                                    <p class="text-sm text-zinc-400 mt-1">Ref. <%= item._id.toString().slice(-6) %></p>
                                </div>
                                <p class="text-lg font-medium">₹ <%= item.price %></p>
                            </div>

                            <div class="flex justify-between items-center mt-6">
                                <div class="flex items-center border-[1.5px] border-zinc-200 rounded-full px-4 py-1 gap-4">
                                    <button class="text-zinc-400 hover:text-black transition-all">-</button>
                                    <span class="text-sm font-bold">01</span>
                                    <button class="text-zinc-400 hover:text-black transition-all">+</button>
                                </div>
                                <a href="/removefromcart/<%= item._id %>"  class="text-xs font-bold uppercase tracking-widest text-zinc-400 hover:text-red-500 transition-all">Remove</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <div class="w-full lg:w-[40%] h-fit lg:sticky lg:top-10">
                <div class="bg-white p-8 rounded-3xl shadow-[0_10px_40px_rgba(0,0,0,0.03)] border-[1px] border-zinc-100">
                    <h2 class="text-xl font-bold mb-8 text-zinc-900">Order Summary</h2>
                    
                    <div class="flex flex-col gap-4 text-sm">
                        <div class="flex justify-between text-zinc-500">
                            <span>Merchandise Total</span>
                            <span class="text-zinc-900 font-medium">₹ <%= bill + (Number(user.cart[0].discount) || 0) - 20 %></span>
                        </div>
                        
                        <div class="flex justify-between text-zinc-500">
                            <span>Estimated Discount</span>
                            <span class="text-green-600 font-bold">- ₹ <%= Number(user.cart[0].discount) %></span>
                        </div>

                        <div class="flex justify-between text-zinc-500">
                            <span>Handling Fee</span>
                            <span class="text-zinc-900 font-medium">₹ 20</span>
                        </div>

                        <div class="flex justify-between text-zinc-500 border-b pb-6">
                            <span>Shipping</span>
                            <span class="text-green-600 font-bold uppercase tracking-tighter">Complimentary</span>
                        </div>

                        <div class="flex justify-between items-end pt-4">
                            <h3 class="text-lg font-bold">Total Bill</h3>
                            <div class="text-right">
                                <p class="text-2xl font-black text-zinc-900">₹ <%= bill %></p>
                                <p class="text-[10px] text-zinc-400 uppercase tracking-widest">Includes all taxes</p>
                            </div>
                        </div>
                    </div>

                    <button class="w-full mt-10 bg-zinc-900 text-white py-5 rounded-2xl font-bold hover:bg-zinc-800 transition-all active:scale-[0.98]">
                        Complete Checkout
                    </button>
                    
                    <div class="mt-6 flex items-center justify-center gap-2">
                        <i class="ri-shield-check-line text-zinc-400"></i>
                        <p class="text-[11px] text-zinc-400 font-medium uppercase tracking-widest">Secure Checkout</p>
                    </div>
                </div>
            </div>

        </div>
    <% } else { %>
        <div class="w-full h-[60vh] flex flex-col items-center justify-center text-center">
            <div class="w-20 h-20 bg-zinc-100 rounded-full flex items-center justify-center mb-6">
                <i class="ri-shopping-bag-line text-3xl text-zinc-300"></i>
            </div>
            <h2 class="text-xl font-bold text-zinc-800">Your cart is feeling lonely.</h2>
            <p class="text-sm text-zinc-400 mt-2">Add some products to make it happy</p>
            <a href="/shop" class="mt-8 px-10 py-3 bg-zinc-900 text-white rounded-full font-bold text-sm">Return to Shop</a>
        </div>
    <% } %>
</div>

<%- include('./partials/footer') %>